@{
    var title = ViewData["Title"] ?? "SteadyFast";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@title - SteadyFast</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        body {
            background: #f5f6fa;
        }

        .navbar-brand {
            font-weight: 600;
            color: #0d1b2a !important;
        }

        .nav-link {
            font-weight: 500;
        }

        .btn-orange {
            background-color: #ea58;
            color: white;
        }

            .btn-orange:hover {
                background-color: #c2410c;
                color: white;
            }

        footer {
            background: #0d1b2a;
            color: white;
            padding: 30px 0;
            margin-top: 60px;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg bg-white shadow-sm">
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                SteadyFast
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">

                <!-- Left menu -->
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Tips">Tips</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                    </li>
                </ul>

                <!-- Right menu -->
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                    </li>

                    <li class="nav-item">
                        <a class="btn btn-orange ms-2" asp-controller="Account" asp-action="Register">
                            Sign Up
                        </a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="fixed-bottom">
        <div class="container text-center ">
            <h5>SteadyFast</h5>
            <p>Reliable mechanical repairs at your doorstep.</p>

            <small>© @DateTime.Now.Year SteadyFast. All rights reserved.</small>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>