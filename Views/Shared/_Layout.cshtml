@{
    var title = ViewData["Title"] ?? "SteadyFast";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@title - SteadyFast</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        /* Active link underline + color */
        .active-link {
            color: #ff7a1a !important;
            position: relative;
        }

            .active-link::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -5px;
                width: 100%;
                height: 2px;
                background-color: #ff7a1a;
            }
        body {
            background: #f5f6fa;
        }

        /* ===== NAVBAR STYLING ===== */
        .custom-navbar {
            background: linear-gradient(90deg, #0d1b2a, #1b263b);
            padding: 12px 0;
        }

        .navbar-brand {
            font-weight: 600;
            color: #ffffff !important;
        }

        /* Center menu links */
        .nav-white {
            color: #ffffff !important;
            font-weight: 500;
            margin: 0 10px;
        }

            .nav-white:hover {
                color: #ff7a1a !important;
            }

        /* Login link (orange text) */
        .login-link {
            color: #ff7a1a !important;
            font-weight: 500;
        }

        /* Sign in button */
        .btn-signin {
            background-color: #ff7a1a;
            color: white;
            font-weight: 500;
            border-radius: 6px;
            padding: 6px 14px;
        }

            .btn-signin:hover {
                background-color: #e66a00;
                color: white;
            }

        /* ===== FOOTER ===== */
        footer {
            background: #0d1b2a;
            color: white;
            padding: 30px 0;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg custom-navbar">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand text-white fw-semibold"
               asp-controller="Home" asp-action="Index">
                SteadyFast
            </a>

            <button class="navbar-toggler bg-light"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">

                <!-- Center Menu -->
                <ul class="navbar-nav mx-auto">

                    <li class="nav-item">
                        <a class="nav-link nav-white @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active-link" : "")"
                           asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-white @(ViewContext.RouteData.Values["action"]?.ToString() == "Tips" ? "active-link" : "")"
                           asp-controller="Home" asp-action="Tips">Tips</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-white @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active-link" : "")"
                           asp-controller="Home" asp-action="About">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-white @(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active-link" : "")"
                           asp-controller="Home" asp-action="Contact">Contact</a>
                    </li>

                </ul>

                <!-- Right Side -->
                <ul class="navbar-nav align-items-center">

                    <li class="nav-item">
                        <a class="nav-link login-link"
                           asp-controller="Account" asp-action="Login">
                            Login
                        </a>
                    </li>

                    <li class="nav-item ms-2">
                        <a class="btn btn-signin"
                           asp-controller="Account" asp-action="Register">
                            Sign in
                        </a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="container-fluid m-4>
        <div class="container mt-4">
            @RenderBody()
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="mt-auto">
        <div class="container text-center py-4">
            <h5>SteadyFast</h5>
            <p>Reliable mechanical repairs at your doorstep.</p>
            <small>© @DateTime.Now.Year SteadyFast. All rights reserved.</small>
        </div>
    </footer>
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>