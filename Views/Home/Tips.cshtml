
@{
    ViewData["Title"] = "Tips";
    // Layout = "~/Views/Shared/_Layout.cshtml";

}

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
    }

    .tips-section {
        position: relative;
        width: 100%;
        min-height: 100vh;
        background: url('@Url.Content("~/Images/bg.jpg")') no-repeat center center;
        background-size: cover;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.65);
        backdrop-filter: blur(4px);
    }

    .tips-content {
        position: relative;
        z-index: 2;
        text-align: center;
        color: white;
        width: 100%;
        padding: 60px 40px;
    }

    .tips-title {
        font-size: 42px;
        font-weight: 600;
        margin-bottom: 50px;
    }

    .tip-card {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 30px;
        color: white;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition: 0.3s ease;
        height: 100%;
    }

        .tip-card:hover {
            transform: translateY(-8px);
            background: rgba(255, 255, 255, 0.15);
        }

    .tip-icon {
        font-size: 45px;
        margin-bottom: 20px;
    }

    .tip-title {
        font-weight: 600;
        font-size: 20px;
        margin-bottom: 15px;
        color: #00c26e;
    }

    .tip-desc {
        font-size: 15px;
        opacity: 0.9;
    }

    .quick-link {
        display: inline-block;
        margin-top: 20px;
        font-style: italic;
        color: #ffffff;
        text-decoration: none;
    }

        .quick-link:hover {
            text-decoration: underline;
        }
</style>

<section class="tips-section">

    <div class="overlay"></div>

    <div class="container tips-content">

        <h2 class="tips-title">Roadside Troubleshooting Tips</h2>

        <div class="row g-4 px-lg-5">

            <!-- Flat Tyre -->
            <div class="col-lg-4 col-md-6">
                <div class="tip-card">
                    <div class="tip-icon text-warning">
                        <i class="bi bi-circle-fill"></i>
                    </div>
                    <div class="tip-title">Flat Tyre</div>
                    <div class="tip-desc">
                        Move to a safe spot, use a jack to lift the car,
                        and replace with a spare or call for assistance.
                    </div>
                    <a href="#" class="quick-link">Quick solution</a>
                </div>
            </div>

            <!-- Dead Battery -->
            <div class="col-lg-4 col-md-6">
                <div class="tip-card">
                    <div class="tip-icon text-success">
                        <i class="bi bi-battery-half"></i>
                    </div>
                    <div class="tip-title">Dead Battery</div>
                    <div class="tip-desc">
                        Try jump-starting with cables. If it still won’t
                        start, the battery might need replacement.
                    </div>
                    <a href="#" class="quick-link">Quick solution</a>
                </div>
            </div>

            <!-- Engine Overheating -->
            <div class="col-lg-4 col-md-6">
                <div class="tip-card">
                    <div class="tip-icon text-danger">
                        <i class="bi bi-thermometer-high"></i>
                    </div>
                    <div class="tip-title">Engine Overheating</div>
                    <div class="tip-desc">
                        Pull over immediately, turn off the engine,
                        and wait for it to cool before checking coolant levels.
                    </div>
                    <a href="#" class="quick-link">Quick solution</a>
                </div>
            </div>

            <!-- Out of Fuel -->
            <div class="col-lg-4 col-md-6">
                <div class="tip-card">
                    <div class="tip-icon text-danger">
                        <i class="bi bi-fuel-pump"></i>
                    </div>
                    <div class="tip-title">Out of Fuel</div>
                    <div class="tip-desc">
                        Avoid frequent low-fuel driving. If empty,
                        call for fuel delivery or walk to the nearest station.
                    </div>
                    <a href="#" class="quick-link">Quick solution</a>
                </div>
            </div>

            <!-- Brake Failure -->
            <div class="col-lg-4 col-md-6">
                <div class="tip-card">
                    <div class="tip-icon text-danger">
                        <i class="bi bi-stop-circle"></i>
                    </div>
                    <div class="tip-title">Brake Failure</div>
                    <div class="tip-desc">
                        Downshift to use engine braking, pump the brakes rapidly,
                        and use the parking brake gently.
                    </div>
                    <a href="#" class="quick-link">Quick solution</a>
                </div>
            </div>

            <!-- Engine Fault -->
            <div class="col-lg-4 col-md-6">
                <div class="tip-card">
                    <div class="tip-icon text-light">
                        <i class="bi bi-gear-fill"></i>
                    </div>
                    <div class="tip-title">Engine Fault</div>
                    <div class="tip-desc">
                        Stop driving if the "Check Engine" light is flashing.
                        Get a professional diagnostic as soon as possible.
                    </div>
                    <a href="#" class="quick-link">Quick solution</a>
                </div>
            </div>

        </div>
    </div>
</section>
